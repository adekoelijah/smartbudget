# ✅ SmartBudget Frontend Environment Configuration
# Copy this file to .env.local and fill in your values for your environment
node_modules
.env
dist
build
coverage
.vercel
.DS_Store
# ==================== API Configuration ====================
# Must match the backend server address and CORS_ORIGINS
VITE_API_URL=http://localhost:5000/api
# Production examples:
VITE_API_URL=https://api.smartbudget.com/api
VITE_API_URL=https://smartbudget.onrender.com/api

# ==================== App Configuration ====================
VITE_APP_NAME=SmartBudget
VITE_APP_VERSION=1.0.0
VITE_NODE_ENV=development
# Options: development, staging, production

# ==================== Feature Flags ====================
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_TRACKING=false
# Set to true in production for better monitoring

# ==================== OAuth Providers (Optional - for social login) ====================
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Get from: https://console.developers.google.com/
# Instructions: Create OAuth 2.0 credentials (Web application)
# Authorized redirect URIs must include your app URL

# ==================== Payment Gateway (Optional - for SaaS subscriptions) ====================
VITE_STRIPE_PUBLIC_KEY=pk_test_your_public_key_here
# For production: use pk_live_... keys
# Get from: https://dashboard.stripe.com/apikeys

# ==================== Error Tracking & Monitoring ====================
VITE_SENTRY_DSN=
# Leave empty for development
# Add your Sentry DSN for production error tracking
# Get from: https://sentry.io/

# ==================== Analytics ====================
VITE_GOOGLE_ANALYTICS_ID=
# Example: G-XXXXXXXXXX (if using Google Analytics)

# ==================== Build Configuration ====================
VITE_ENABLE_SOURCE_MAPS=true
# Set to false for production to reduce bundle size and improve performance

